# --- Server (Express + PostgreSQL) ---

# Either use DATABASE_URL (recommended, works for managed Postgres hosts
# like Render/Railway/Supabase/Neon)...
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/portfolio_db

# ...or leave DATABASE_URL blank and fill these in instead:
# PGHOST=localhost
# PGPORT=5432
# PGUSER=postgres
# PGPASSWORD=postgres
# PGDATABASE=portfolio_db

PORT=5000
NODE_ENV=development

# Origin(s) allowed to call the API (comma-separated). Only matters if the
# frontend is served from a different origin than the API.
CLIENT_ORIGIN=http://localhost:5173

# --- Client (Vite) ---
# Optional — override where the contact form submits to. Leave unset to use
# the relative /api/contact path (works automatically in dev via the Vite
# proxy, and in production since one server serves both).
# VITE_CONTACT_ENDPOINT=/api/contact
